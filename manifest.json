{
  "manifest_version": 3,
  "name": "Notion AI Chat Scraper",
  "version": "0.1.0",
  "description": "Captures and exports Notion AI chat conversations as Markdown or JSON.",

  "permissions": [
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "https://www.notion.so/*",
    "https://notion.so/*"
  ],

  "background": {
    "scripts": ["background/service-worker.js"],
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://www.notion.so/*", "https://notion.so/*"],
      "js": ["content/interceptor.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Notion AI Scraper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "notion-ai-scraper@local",
      "strict_min_version": "109.0"
    }
  }
}
