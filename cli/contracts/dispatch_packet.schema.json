{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dispatch_packet.schema.json",
  "title": "Dispatch Packet",
  "description": "A validated work item ready for execution by an execution plane.",
  "type": "object",
  "required": [
    "version", "run_id", "work_item_id", "work_item_name",
    "objective", "execution_lane", "environment",
    "type", "created_at", "constraints"
  ],
  "properties": {
    "version":        {"type": "string", "const": "1.1"},
    "run_id":         {"type": "string", "format": "uuid"},
    "work_item_id":   {"type": "string", "format": "uuid"},
    "work_item_name": {"type": "string", "minLength": 1},
    "project_name":   {"type": ["string", "null"]},
    "project_id":     {"type": ["string", "null"], "format": "uuid"},
    "objective":      {"type": "string", "minLength": 1},
    "kill_condition":  {"type": ["string", "null"]},
    "dispatch_via":   {
      "type": ["string", "null"],
      "enum": ["Claude", "Claude Code", "Gemini", "Cursor", "Codex", "Copilot", "Antigravity", "Manual", null]
    },
    "execution_lane": {
      "type": "string",
      "enum": [
        "main", "planner", "coder", "reviewer", "dev",
        "sentinel", "sentinel-deploy", "scout",
        "bayview", "bayview-thinking", "bayview-tuning",
        "thinker", "ops", "writers-room"
      ]
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "staging", "production", "sandbox"]
    },
    "branch":          {"type": ["string", "null"]},
    "type": {
      "type": "string",
      "enum": ["Gauntlet", "Measurement Track", "Literature Survey", "Design Spec", "Feasibility Analysis", "Implementation", "Operational", "Review", "Experiment", "Fact-Check", "Creative", "Other"]
    },
    "prompt_notes":    {"type": ["string", "null"]},
    "repo_url": {"type": ["string", "null"], "format": "uri"},
    "github_issue_url": {"type": ["string", "null"], "format": "uri"},
    "cascade_depth":   {"type": "integer", "minimum": 1, "default": 1},
    "concurrency_group": {"type": ["string", "null"]},
    "execution_budget": {"type": ["number", "null"]},
    "retry_count": {"type": "integer", "minimum": 0, "default": 0},
    "dispatch_mode": {
      "type": "string",
      "enum": ["execute", "incubate"],
      "default": "execute"
    },
    "dispatch_block": {
      "type": "string",
      "enum": ["none", "pre_repo_incubation", "safety_hold"],
      "default": "none"
    },
    "repo_ready": {"type": "boolean", "default": false},
    "escalation_level": {
      "type": "string",
      "enum": ["Normal", "Needs Sam", "Critical"],
      "default": "Normal"
    },
    "project_focus": {"type": "boolean", "default": false},
    "project_min_terminal_value": {
      "type": "string",
      "enum": ["Any", "Meaningful", "High"],
      "default": "Any"
    },
    "project_fork_budget": {"type": ["number", "null"]},
    "portfolio_focus_active": {"type": "boolean", "default": false},
    "created_at":      {"type": "string", "format": "date-time"},
    "constraints": {
      "type": "object",
      "required": ["can_code", "can_browse", "can_deploy", "max_timeout_s"],
      "properties": {
        "can_code":      {"type": "boolean"},
        "can_browse":    {"type": "boolean"},
        "can_deploy":    {"type": "boolean"},
        "write_scope":   {"type": "string"},
        "max_timeout_s": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "writers_room_config": {
      "type": ["object", "null"],
      "description": "Writers-room pipeline configuration. Required when execution_lane is 'writers-room'. See pontius_scene_items.schema.json for field definitions.",
      "required": ["task_type", "scene_name", "creative_brief"],
      "properties": {
        "task_type": {
          "type": "string",
          "enum": ["Full Scene Draft", "Scene Revision", "Beat Sheet Only", "Research Query", "Character Development", "Episode Outline", "Dialogue Polish", "Motif Placement"]
        },
        "scene_name":     {"type": "string", "minLength": 1},
        "season":         {"type": ["integer", "null"], "minimum": 1, "maximum": 4},
        "episode":        {"type": ["integer", "null"], "minimum": 1},
        "revision_pass":  {"type": "integer", "minimum": 1, "default": 1},
        "creative_brief": {"type": "string", "minLength": 1},
        "character_list": {"type": "array", "items": {"type": "string"}},
        "scene_item_id":  {"type": ["string", "null"], "format": "uuid", "description": "Notion page ID of the pontius_scene_items row. Null if the dispatcher should create one."},
        "prior_artifacts": {
          "type": ["object", "null"],
          "description": "Notion page IDs of step outputs from a previous pass, carried forward on revision.",
          "properties": {
            "source_audit_id":        {"type": ["string", "null"]},
            "classification_id":      {"type": ["string", "null"]},
            "character_clearance_id": {"type": ["string", "null"]},
            "motif_audit_id":         {"type": ["string", "null"]},
            "beat_sheet_id":          {"type": ["string", "null"]},
            "scene_draft_id":         {"type": ["string", "null"]},
            "stress_test_id":         {"type": ["string", "null"]}
          }
        }
      }
    }
  },
  "additionalProperties": false
}
